# ==============================================================================
# InsureConnect Web (Next.js) Environment Variables
# ==============================================================================
# Frontend application configuration
# This file is used for development; production uses deployment platform config
# ==============================================================================

# ==============================================================================
# API Configuration
# ==============================================================================
# Public API base URL - used by browser when calling API endpoints
# Development:  http://localhost:4000
# Docker:       http://localhost/api (behind nginx)
# Production:   https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Internal API URL for server-side requests (Next.js API routes)
# Used only in server-side components and API route handlers
# Development:  http://localhost:4000
# Docker:       http://nginx/api or http://api:4000 (internal network)
# Production:   http://insureconnect-api:4000 (internal Docker network)
INTERNAL_API_BASE_URL="http://localhost:4000"

# Public application URL visible to end users
# Development:  http://localhost:3000
# Docker:       http://localhost
# Production:   https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==============================================================================
# Next.js Specific Configuration
# ==============================================================================
# Disable Next.js telemetry (set to "1" to disable, "0" to enable)
NEXT_TELEMETRY_DISABLED="1"

# ==============================================================================
# Environment Profile
# ==============================================================================
# NODE_ENV is typically set by deployment platform:
# - Development builds: NODE_ENV=development
# - Production builds:  NODE_ENV=production
# - Staging deploys:    NODE_ENV=production (app code) with staging URLs

# ==============================================================================
# Authentication Configuration
# ==============================================================================
# Cookie settings for auth tokens (managed via HTTP-only cookies from API)
# Development:  Cookies sent over http:// (secure: false)
# Production:   Cookies sent over https:// only (secure: true, sameSite: strict)
# These are set automatically based on NODE_ENV in auth route handlers

# ==============================================================================
# Optional: Feature Flags
# ==============================================================================
# Enable/disable specific features
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ==============================================================================
# Optional: Monitoring & Observability
# ==============================================================================
# For integrating with monitoring services (Sentry, LogRocket, etc.)
# NEXT_PUBLIC_SENTRY_DSN=https://...
# NEXT_PUBLIC_LOG_LEVEL=info
# ==============================================================================