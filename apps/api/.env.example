# ==============================================================================
# InsureConnect API Server Environment Variables
# ==============================================================================
# Local NestJS API configuration
# This file is used for development; production uses secrets management
# ==============================================================================

# ==============================================================================
# Environment Profile
# ==============================================================================
NODE_ENV="development"
LOG_LEVEL="debug"

# ==============================================================================
# Server Configuration
# ==============================================================================
PORT="4000"
CORS_ORIGIN="http://localhost:3000"

# ==============================================================================
# Database Configuration
# ==============================================================================
# PostgreSQL connection for Prisma ORM
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insureconnect_dev?schema=public"

# ==============================================================================
# Redis / Queue Configuration
# ==============================================================================
# Redis for Bull job queue processing
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# ==============================================================================
# Authentication & Security
# ==============================================================================
# JWT token signing secrets (minimum 32 characters)
JWT_SECRET="dev-jwt-secret-change-in-production-min-32-chars-secure-this"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-in-production-min-32-chars-secure-this"

# ==============================================================================
# Optional: Advanced Configuration
# ==============================================================================
# Rate limiting and API features
# RATE_LIMIT_PER_MINUTE=100

# Queue processing settings
# QUEUE_ENABLED=true
# JOB_MAX_RETRIES=3
# JOB_BACKOFF_DELAY=2000

# Webhook configuration
# WEBHOOKS_ENABLED=true
# WEBHOOK_TIMEOUT_MS=5000
# ==============================================================================