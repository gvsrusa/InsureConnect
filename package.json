{
  "name": "insureconnect",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "prisma"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "prisma:generate": "npm --workspace prisma run generate",
    "prisma:seed": "npm --workspace prisma run seed",
    "compose:up": "docker compose -f infra/docker-compose.yml up --build -d",
    "compose:down": "docker compose -f infra/docker-compose.yml down",
    "compose:up:prod": "docker compose -f infra/docker-compose.prod.yml up --build -d",
    "compose:down:prod": "docker compose -f infra/docker-compose.prod.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
