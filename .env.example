# ==============================================================================
# InsureConnect Environment Variables
# ==============================================================================
# Copy this file to .env and update the values for your environment
# DO NOT commit .env to version control - it contains sensitive data
#
# Development:  Run `cp .env.example .env` and update localhost values
# Production:   Use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)
# ==============================================================================

# ==============================================================================
# Database Configuration
# ==============================================================================
# PostgreSQL connection string for the main application database
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insureconnect_dev?schema=public"

# ==============================================================================
# Redis / Queue Configuration
# ==============================================================================
# Redis configuration for job queues and caching
# Option 1: Use individual Redis configuration parameters (preferred for complex setups)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""                          # Leave empty if no password is set
REDIS_DB="0"                              # Redis database number (0-15)

# Option 2: Use Redis connection URL (alternative format)
# REDIS_URL="redis://localhost:6379"
# REDIS_URL="redis://:password@host:6379/db" (if password required)

# ==============================================================================
# Server Configuration
# ==============================================================================
# API server port
PORT="4000"

# Environment mode (development, staging, production)
NODE_ENV="development"

# Log level (error, warn, log, debug, verbose) - NestJS logger level
LOG_LEVEL="debug"

# ==============================================================================
# Authentication & Security
# ==============================================================================
# JWT signing secret - used to sign access tokens
# ⚠️  IMPORTANT: Use a strong secret (min 32 characters) in production
# Generate: `openssl rand -base64 32`
JWT_SECRET="dev-jwt-secret-change-in-production-min-32-chars-secure-this"

# JWT refresh token secret - used for refresh token signing
# ⚠️  IMPORTANT: Use a different secret from JWT_SECRET in production
# Generate: `openssl rand -base64 32`
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-in-production-min-32-chars-secure-this"

# ==============================================================================
# CORS Configuration
# ==============================================================================
# Allowed origin for cross-origin requests from web clients
# Development:  http://localhost:3000
# Production:  https://yourdomain.com (with https protocol)
CORS_ORIGIN="http://localhost:3000"

# ==============================================================================
# API & Application URLs
# ==============================================================================
# Base URL for API calls from frontend
# Used in browser to fetch API data
# Development:  http://localhost:4000 or http://localhost/api
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Internal API URL for server-to-server communication (Next.js to NestJS)
# Used only on the server side in Next.js API routes
# Development:  http://localhost:4000 or http://api:4000 (in Docker)
# Production:  http://insureconnect-api:4000 (internal Docker network)
INTERNAL_API_BASE_URL="http://localhost:4000"

# Public application URL visible to users
# Development:  http://localhost:3000 or http://localhost
# Production:  https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==============================================================================
# Next.js Specific Configuration
# ==============================================================================
# Disable Next.js telemetry data collection
# Set to "1" to disable, "0" to enable
NEXT_TELEMETRY_DISABLED="1"

# ==============================================================================
# Optional: Feature Flags & Advanced Configuration
# ==============================================================================
# Enable/disable queue processing for asynchronous jobs
# QUEUE_ENABLED=true

# Enable/disable webhook event processing
# WEBHOOKS_ENABLED=true

# Maximum number of job retries for async processing
# JOB_MAX_RETRIES=3

# Job retry backoff delay in milliseconds
# JOB_BACKOFF_DELAY=2000

# ==============================================================================
# Docker Compose Specific (for production docker-compose.yml)
# ==============================================================================
# When using docker-compose, these values override the above for services
# See infra/docker-compose.yml and infra/docker-compose.prod.yml for reference
#
# POSTGRES_DB=insureconnect
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secure-password-here
#
# Redis remains accessible on redis:6379 from within Docker network
# ==============================================================================

# ==============================================================================
# Environment Profiles
# ==============================================================================
# Development Profile (.env for local development):
#   - NODE_ENV=development
#   - LOG_LEVEL=debug
#   - Localhost URLs
#   - Dev/test credentials
#
# Staging Profile (.env.staging for pre-production testing):
#   - NODE_ENV=staging
#   - LOG_LEVEL=log
#   - Staging domain URLs
#   - Real database/Redis
#   - Strong secrets
#
# Production Profile (.env.production for live deployment):
#   - NODE_ENV=production
#   - LOG_LEVEL=error
#   - Production domain URLs
#   - Managed database/Redis (AWS RDS, AWS ElastiCache, etc.)
#   - Very strong secrets (use secrets manager)
#   - HTTPS for all URLs
# ==============================================================================

# ==============================================================================
# Documentation & Support
# ==============================================================================
# For detailed configuration documentation, see:
# - docs/architecture.md - System design and environment setup
# - DEVELOPMENT_CHECKLIST.md - Step-by-step local development setup
# - README.md - General project information
#
# Key Environment Variable Guidelines:
# 1. Database: Use PostgreSQL 14+ with schema migrations
# 2. Redis: Required for job queues; must be running before API starts
# 3. JWT Secrets: Store securely; rotate periodically in production
# 4. URLs: Must include protocol (http:// or https://)
# 5. NODE_ENV: Controls app behavior (logging, error handling, cookies)
# =============================================================================="