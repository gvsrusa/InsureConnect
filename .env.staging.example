# ==============================================================================
# InsureConnect Staging Environment Configuration
# ==============================================================================
# Pre-production environment for testing and validation
# Uses real (staging) infrastructure but non-production data
# ============================================================================== 

# ==============================================================================
# Environment Profile
# ==============================================================================
NODE_ENV="production"                    # Production-like build, but staging behavior
LOG_LEVEL="log"                          # Detailed logging for debugging

# ==============================================================================
# Server Configuration
# ==============================================================================
PORT="4000"
CORS_ORIGIN="https://staging.yourdomain.com"

# ==============================================================================
# Database Configuration (STAGING)
# ==============================================================================
# Use staging PostgreSQL database (not production data)
# Can be smaller instance than production
DATABASE_URL="postgresql://staginguser:STAGING_PASSWORD@insureconnect-staging-db.xxxxx.us-east-1.rds.amazonaws.com:5432/insureconnect_staging?schema=public&sslmode=require"

# ==============================================================================
# Redis / Queue Configuration (STAGING)
# ==============================================================================
# Use staging Redis instance
REDIS_HOST="insureconnect-staging-redis.xxxxx.ng.0001.use1.cache.amazonaws.com"
REDIS_PORT="6379"
REDIS_PASSWORD="STAGING_REDIS_PASSWORD"
REDIS_DB="0"

# ==============================================================================
# Authentication & Security (STAGING)
# ==============================================================================
# Use staging secrets (different from production but still secure)
# These can be shared in documentation for team testing
JWT_SECRET="staging-jwt-secret-min-32-chars-for-testing-replace-in-prod"
JWT_REFRESH_SECRET="staging-jwt-refresh-secret-min-32-chars-for-testing-replace-in-prod"

# ==============================================================================
# API & Application URLs (STAGING)
# ==============================================================================
NEXT_PUBLIC_API_BASE_URL="https://api-staging.yourdomain.com"
INTERNAL_API_BASE_URL="http://insureconnect-api:4000"
NEXT_PUBLIC_APP_URL="https://staging.yourdomain.com"

# ==============================================================================
# Next.js Configuration (STAGING)
# ==============================================================================
NEXT_TELEMETRY_DISABLED="1"

# ==============================================================================
# Staging-Specific Configuration
# ==============================================================================
# Enable beta features for testing
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=true

# More verbose logging for debugging
# LOG_LEVEL=debug

# Queue processing with higher retry count for resilience testing
# QUEUE_ENABLED=true
# JOB_MAX_RETRIES=5

# APM for staging environment (optional)
# NEXT_PUBLIC_SENTRY_DSN="https://staging-key@sentry.io/xxxxx"

# ==============================================================================
# Staging Deployment Notes
# ==============================================================================
# - Use close-to-production infrastructure setup
# - Can point to staging DNS names
# - Use HTTPS for all external URLs
# - Data should be non-sensitive test data only
# - Can be used for:
#   * Load testing
#   * UAT (User Acceptance Testing)
#   * Integration testing
#   * Performance validation
# =============================================================================="