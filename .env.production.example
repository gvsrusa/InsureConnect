# ==============================================================================
# InsureConnect Production Environment Configuration
# ==============================================================================
# ⚠️  CRITICAL: This is a TEMPLATE only. DO NOT use literal values in production.
# Use AWS Secrets Manager, HashiCorp Vault, or similar for secret management.
# Never commit sensitive values to version control.
# ==============================================================================

# ==============================================================================
# Environment Profile
# ==============================================================================
NODE_ENV="production"
LOG_LEVEL="error"                         # Minimal logging in production

# ==============================================================================
# Server Configuration
# ==============================================================================
PORT="4000"
CORS_ORIGIN="https://yourdomain.com"     # Production domain only

# ==============================================================================
# Database Configuration  (PRODUCTION)
# ==============================================================================
# Use AWS RDS, Google Cloud SQL, or managed PostgreSQL service
# Format: postgresql://user:password@prod-host:5432/database?schema=public
# ⚠️  Use strong password from secrets manager
DATABASE_URL="postgresql://produser:REPLACE_WITH_STRONG_PASSWORD@insureconnect-db.xxxxx.us-east-1.rds.amazonaws.com:5432/insureconnect?schema=public&sslmode=require"

# ==============================================================================
# Redis / Queue Configuration (PRODUCTION)
# ==============================================================================
# Use AWS ElastiCache, Google Memorystore, or managed Redis service
# Format: redis://:password@host:port
REDIS_HOST="insureconnect-redis.xxxxx.ng.0001.use1.cache.amazonaws.com"
REDIS_PORT="6379"
REDIS_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"
REDIS_DB="0"

# ==============================================================================
# Authentication & Security (PRODUCTION)
# ==============================================================================
# ⚠️  CRITICAL: Use cryptographically secure random secrets (min 32 chars)
# Generate: openssl rand -base64 48
# Rotate these secrets periodically (at least annually)
# Store in AWS Secrets Manager or similar
JWT_SECRET="REPLACE_WITH_SECURE_32_PLUS_CHAR_SECRET_FROM_SECRETS_MANAGER"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_SECURE_32_PLUS_CHAR_SECRET_FROM_SECRETS_MANAGER"

# ==============================================================================
# API & Application URLs (PRODUCTION)
# ==============================================================================
# All URLs must use HTTPS in production
NEXT_PUBLIC_API_BASE_URL="https://api.yourdomain.com"
INTERNAL_API_BASE_URL="http://insureconnect-api:4000"  # Internal Docker network
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ==============================================================================
# Next.js Configuration (PRODUCTION)
# ==============================================================================
NEXT_TELEMETRY_DISABLED="1"

# ==============================================================================
# Advanced Production Configuration
# ==============================================================================
# Rate limiting - adjust based on expected load
# RATE_LIMIT_PER_MINUTE=1000

# Queue processing
# QUEUE_ENABLED=true
# JOB_MAX_RETRIES=5
# JOB_BACKOFF_DELAY=3000

# Monitoring and APM (Application Performance Monitoring)
# NEXT_PUBLIC_SENTRY_DSN="https://example@sentry.io/xxxxx"
# NEW_RELIC_LICENSE_KEY="REPLACE_WITH_LICENSE_KEY"
# DATADOG_API_KEY="REPLACE_WITH_API_KEY"

# ==============================================================================
# Docker Compose Production Override (.env.prod)
# ==============================================================================
# Additional variables for docker-compose.prod.yml:
# POSTGRES_DB=insureconnect
# POSTGRES_USER=produser
# POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# COMPOSE_PROJECT_NAME=insureconnect-prod

# ==============================================================================
# Production Deployment Checklist
# ==============================================================================
# Before deploying to production:
# ✓ All environment variables set via secure secrets manager
# ✓ CORS_ORIGIN points to production domain(s) only
# ✓ Database uses TLS/SSL connections (sslmode=require)
# ✓ Redis has password protection enabled
# ✓ JWT_SECRET and JWT_REFRESH_SECRET are strong and different
# ✓ NODE_ENV=production
# ✓ LOG_LEVEL=error or warn
# ✓ All URLs use https:// protocol
# ✓ HTTPS certificates are valid and renewed
# ✓ Rate limiting configured appropriately
# ✓ Backups configured for database and Redis
# ✓ Monitoring and alerting connected
# ✓ Error tracking (Sentry, etc.) configured
# =============================================================================="